{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "analyst",
  "username": "cosimo",
  "autoupdate": false,
  "compaction": {
    "auto": true
  },
  "instructions": [
    "~/.config/opencode/rules.md"
  ],
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "general": { "disable": true },
    "explore": { "disable": true }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["mcp-server-sequential-thinking"]
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "tool_output": {
    "max_lines": 3000,
    "max_bytes": 102400
  },
  "snapshot": false,
  "enabled_providers": ["stargate", "opencode-go"],
  "lsp": true,
  "plugin": [
    "@dietrichgebert/ponytail@4.8.3"
  ]
}
